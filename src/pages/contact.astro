---
import Layout from '../layouts/Layout.astro';
import site from '../data/site.json';

const curriculumModules = import.meta.glob('../data/curriculum/*.json', { eager: true });
const curriculum = Object.entries(curriculumModules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([path, mod]: [string, any]) => ({
    slug: path.split('/').pop()!.replace('.json', ''),
    ...mod.default,
  }));

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
---

<Layout
  title="Contact &amp; Registration"
  css="contact"
  heroImage="/assets/images/curriculum-hero.png"
  navPage="contact"
>
  <section class="contact-info">
    <div class="container">
      <h2>Get in Touch</h2>
      <div class="contact-cards">
        <div class="info-card">
          <div class="info-card-header">
            <h3>Address</h3>
            <div class="info-card-icon info-card-icon--green">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00A63E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
          </div>
          <p>
            {site.address.street}<br />
            {site.address.city}, {site.address.province} {site.address.postal}<br />
            {site.address.country}
          </p>
        </div>

        <div class="info-card">
          <div class="info-card-header">
            <h3>Email</h3>
            <div class="info-card-icon info-card-icon--yellow">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D08700" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
          </div>
          <p>
            <strong>General:</strong> <a href={`mailto:${site.email.general}`}>{site.email.general}</a><br />
            <strong>Admissions:</strong> <a href={`mailto:${site.email.admissions}`}>{site.email.admissions}</a><br />
            <strong>Payments:</strong> <a href={`mailto:${site.email.payments}`}>{site.email.payments}</a><br />
            <strong>Students &amp; Parents:</strong> <a href={`mailto:${site.email.students}`}>{site.email.students}</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="contact-form-section section-tinted">
    <div class="container">
      <h2>Enrollment Inquiry Form</h2>
      <p class="contact-form-intro">Fill out this form to start the enrollment process or ask questions about our programs.</p>

      <form class="contact-form" action="/api/contact" method="post">
        <!-- Honeypot: hidden from humans, filled by bots -->
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
        <div class="contact-form-group">
          <label class="contact-form-label">Enrollment Type</label>
          <div class="contact-form-radio-group">
            <label class="contact-form-radio">
              <input type="radio" name="enrollment-type" value="new" checked />
              <span>New Student</span>
            </label>
            <label class="contact-form-radio">
              <input type="radio" name="enrollment-type" value="returning" />
              <span>Returning Student</span>
            </label>
          </div>
        </div>

        <div class="contact-form-row">
          <div class="contact-form-group">
            <label for="parent-name" class="contact-form-label">Parent/Guardian Name *</label>
            <input type="text" id="parent-name" name="parent-name" placeholder="Your full name" required />
          </div>
          <div class="contact-form-group">
            <label for="email" class="contact-form-label">Email Address *</label>
            <input type="email" id="email" name="email" placeholder="your.email@example.com" required />
          </div>
        </div>

        <fieldset class="contact-form-fieldset">
          <legend>Student Information</legend>
          <div class="contact-form-row">
            <div class="contact-form-group">
              <label for="child-name" class="contact-form-label">Child's Name *</label>
              <input type="text" id="child-name" name="child-name" placeholder="Child's full name" required />
            </div>
            <div class="contact-form-group">
              <label for="child-age" class="contact-form-label">Child's Age *</label>
              <input type="number" id="child-age" name="child-age" placeholder="Age" min="3" max="18" required />
            </div>
          </div>
          <div class="contact-form-group">
            <label for="grade-level" class="contact-form-label">Desired Grade Level *</label>
            <select id="grade-level" name="grade-level" required>
              <option value="" disabled selected>Select a grade level</option>
              {curriculum.map((level) => (
                <option value={level.slug}>{level.title}</option>
              ))}
            </select>
            <!-- Populated by JS so the function receives the human-readable title -->
            <input type="hidden" id="grade-title" name="grade-title" />
          </div>
        </fieldset>

        <div class="contact-form-group">
          <label for="message" class="contact-form-label">Questions or Comments</label>
          <textarea id="message" name="message" rows={5} placeholder="Tell us about your child's Portuguese language experience, any questions you have, or special considerations..."></textarea>
        </div>

        <div class="contact-form-actions">
          <div class="cf-turnstile" data-sitekey={turnstileSiteKey}></div>
          <button type="submit" class="btn-primary">Submit Enrollment Inquiry</button>
          <p class="contact-form-note">* Required fields. We'll contact you within 2 business days.</p>
        </div>
      </form>
    </div>
  </section>
</Layout>

<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  const gradeSelect = document.getElementById('grade-level') as HTMLSelectElement;
  const gradeTitleInput = document.getElementById('grade-title') as HTMLInputElement;
  gradeSelect.addEventListener('change', () => {
    gradeTitleInput.value = gradeSelect.options[gradeSelect.selectedIndex].text;
  });

  const form = document.querySelector('.contact-form') as HTMLFormElement;
  const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
  const ORIGINAL_BTN_TEXT = submitBtn.textContent ?? 'Submit Enrollment Inquiry';

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const prevError = form.querySelector('.form-error');
    if (prevError) prevError.remove();

    const formData = new FormData(form);
    const childName = (formData.get('child-name') as string) || 'your child';

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    try {
      const res = await fetch('/api/contact', { method: 'POST', body: formData });
      const data = await res.json();

      if (data.success) {
        const container = document.querySelector('.contact-form-section .container') as HTMLElement;
        const heading = container.querySelector('h2');
        const intro = container.querySelector('.contact-form-intro');
        if (heading) heading.remove();
        if (intro) intro.remove();

        const successDiv = document.createElement('div');
        successDiv.className = 'form-success';
        successDiv.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <h2>Inquiry Received!</h2>
          <p>Thank you for your enrollment inquiry. We'll be in touch within 2 business days.</p>
          <p>If you need to reach us sooner, email <a href="mailto:admissions@escolaportuguesayvr.ca">admissions@escolaportuguesayvr.ca</a>.</p>
        `;
        // Insert child name safely (no XSS)
        const p = successDiv.querySelectorAll('p')[0];
        p.innerHTML = 'Thank you for your enrollment inquiry for <strong></strong>. We\'ll be in touch within 2 business days.';
        (p.querySelector('strong') as HTMLElement).textContent = childName;

        form.replaceWith(successDiv);
      } else {
        showError(data.error || 'Something went wrong. Please try again.');
      }
    } catch {
      showError('Network error. Please check your connection and try again.');
    }
  });

  function showError(msg: string) {
    submitBtn.disabled = false;
    submitBtn.textContent = ORIGINAL_BTN_TEXT;
    if ((window as any).turnstile) (window as any).turnstile.reset();

    const errorP = document.createElement('p');
    errorP.className = 'form-error';
    errorP.textContent = msg;
    form.querySelector('.contact-form-actions')!.prepend(errorP);
    errorP.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
</script>
