---
import Layout from '../layouts/Layout.astro';
import site from '../data/site.json';
import calendar from '../data/calendar.json';
---

<Layout
  title="Calendar"
  css="calendar"
  heroImage="/assets/images/curriculum-hero.png"
  navPage="calendar"
>
  <section class="calendar-intro">
    <div class="container">
      <div class="calendar-meta">
        <div class="info-card">
          <div class="info-card-header">
            <h3>School Year</h3>
            <div class="info-card-icon info-card-icon--green">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00A63E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            </div>
          </div>
          <p>{site.schoolYear.start} &ndash; {site.schoolYear.end}</p>
        </div>
        <div class="info-card">
          <div class="info-card-header">
            <h3>Class Days</h3>
            <div class="info-card-icon info-card-icon--blue">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#155DFC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
          </div>
          <p>{site.classDays}</p>
        </div>
        <div class="info-card">
          <div class="info-card-header">
            <h3>Location</h3>
            <div class="info-card-icon info-card-icon--yellow">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D08700" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
          </div>
          <p>{site.address.street}, {site.address.city}, {site.address.province}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="calendar-dates">
    <div class="container">
      <h2>Important Dates</h2>

      <div class="calendar-list">
        {calendar.map((event: any) => (
          <div class="calendar-item">
            <div class="calendar-item-date">
              <span class="calendar-item-month">{event.month}</span>
              <span class="calendar-item-day">{event.day}</span>
            </div>
            <div class="calendar-item-content">
              <h3>{event.title}</h3>
              <span class={`calendar-tag calendar-tag--${event.tag}`}>
                {event.tag.charAt(0).toUpperCase() + event.tag.slice(1)}
              </span>
              <p set:html={event.description} />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="calendar-fundraiser section-tinted">
    <div class="container">
      <h2>Dinner &amp; Dance Fundraiser</h2>
      <p>Our school&rsquo;s Dinner and Dance fundraiser takes place twice a year, in the Fall and in the Spring. During these events, tickets are sold to parents and friends who wish to attend.</p>
      <p>Parents who would like to organize fundraising events to support our school are always welcome to do so. Funds raised are used to support school programs, purchase learning materials, organize cultural activities, and improve school resources for the students.</p>
    </div>
  </section>
</Layout>
