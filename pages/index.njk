---
title: Home
layout: layout.njk
hideTitle: true
css: home
---

<section class="home-hero">
  <div class="home-hero-bg">
    <img src="/assets/images/hero-bg.png" alt="" />
  </div>
  <div class="home-hero-content">
    <div class="home-hero-text">
      <h1>{{ home.hero.heading | safe }}</h1>
      <p class="home-hero-lead">{{ home.hero.lead }}</p>
      <div class="home-hero-badge">
        <span>{{ home.hero.badge }}</span>
      </div>
    </div>
    <div class="home-hero-cta">
      <a href="/contact" class="btn-primary">REGISTER NOW</a>
      <span class="home-hero-cta-tag">{{ home.hero.enrolmentTag }}</span>
    </div>
  </div>
</section>

<section class="home-school">
  <div class="container home-school-grid">
    <div class="home-school-image">
      <img src="/assets/images/our-school.png" alt="Our School" />
    </div>
    <div class="home-school-content">
      <h2>{{ home.school.heading }}</h2>
      <p class="lead">{{ home.school.lead }}</p>
      <p>{{ home.school.body }}</p>
      <a href="/about" class="btn-outline">LEARN MORE</a>
    </div>
  </div>
</section>

<section class="home-curriculum">
  <div class="container">
    <h2>{{ home.curriculumSection.heading }}</h2>
    <p class="home-curriculum-intro">{{ home.curriculumSection.intro }}</p>
    <div class="home-curriculum-pills">
      {% for slug, level in curriculum %}
        <a href="/curriculum#{{ slug }}" class="pill pill-{{ loop.index }}">{{ level.title }}</a>
      {% endfor %}
    </div>
  </div>
</section>

<section class="home-teachers">
  <div class="container home-teachers-grid">
    <div class="home-teachers-content">
      <h2>{{ home.teachersSection.heading }}</h2>
      <p>{{ home.teachersSection.body }}</p>
      <a href="/about#our-teachers" class="btn-outline">MEET THE TEACHERS</a>
    </div>
    <div class="home-teachers-image">
      <img src="/assets/images/our-teachers.png" alt="Our Teachers" />
    </div>
  </div>
</section>

<section class="home-cta">
  <div class="home-cta-bg">
    <img src="/assets/images/cta-bg.png" alt="" />
  </div>
  <div class="home-cta-content">
    <h2>{{ home.cta.heading }}</h2>
    <p>{{ home.cta.body }}</p>
    <a href="/contact" class="btn-primary">REGISTER NOW</a>
  </div>
</section>
