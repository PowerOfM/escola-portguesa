<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>
      {{ title }} - Escola Portuguesa Nossa Senhora de Fátima - Vancouver, BC
    </title>
    <link rel="stylesheet" href="/assets/css/reset.css" />
    <link rel="stylesheet" href="/assets/css/main.css" />
    {% if css %}
    <link rel="stylesheet" href="/assets/css/{{ css }}.css" />
    {% endif %}
  </head>
  <body{% if hideTitle %} class="home"{% endif %}>
    <!-- global header -->
    {% include "header.njk" %}

    <!-- page hero / title -->
    {% if heroImage %}
    <section class="page-hero">
      <div class="page-hero-bg">
        <img src="{{ heroImage }}" alt="" />
      </div>
      <div class="page-hero-content">
        <h1>{{ title }}</h1>
      </div>
    </section>
    <div class="page-divider"></div>
    {% elif not hideTitle %}
    <section class="page-title">
      <div class="container">
        <h1>{{ title }}</h1>
      </div>
    </section>
    <div class="page-divider"></div>
    {% endif %}

    <main>{{ content | safe }}</main>

    {% include "footer.njk" %}
  </body>
</html>
