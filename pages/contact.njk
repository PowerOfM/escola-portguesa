<section class="contact-form-section">
  <div class="container">
    <h2>Enrollment Inquiry Form</h2>
    <p class="contact-form-intro">Fill out this form to start the enrollment process or ask questions about our programs.</p>

    <form class="contact-form" action="#" method="post">
      <div class="contact-form-group">
        <label class="contact-form-label">Enrollment Type</label>
        <div class="contact-form-radio-group">
          <label class="contact-form-radio">
            <input type="radio" name="enrollment-type" value="new" checked />
            <span>New Student</span>
          </label>
          <label class="contact-form-radio">
            <input type="radio" name="enrollment-type" value="returning" />
            <span>Returning Student</span>
          </label>
        </div>
      </div>

      <div class="contact-form-row">
        <div class="contact-form-group">
          <label for="parent-name" class="contact-form-label">Parent/Guardian Name *</label>
          <input type="text" id="parent-name" name="parent-name" placeholder="Your full name" required />
        </div>
        <div class="contact-form-group">
          <label for="email" class="contact-form-label">Email Address *</label>
          <input type="email" id="email" name="email" placeholder="your.email@example.com" required />
        </div>
      </div>

      <fieldset class="contact-form-fieldset">
        <legend>Student Information</legend>
        <div class="contact-form-row">
          <div class="contact-form-group">
            <label for="child-name" class="contact-form-label">Child's Name *</label>
            <input type="text" id="child-name" name="child-name" placeholder="Child's full name" required />
          </div>
          <div class="contact-form-group">
            <label for="child-age" class="contact-form-label">Child's Age *</label>
            <input type="number" id="child-age" name="child-age" placeholder="Age" min="3" max="18" required />
          </div>
        </div>
        <div class="contact-form-group">
          <label for="grade-level" class="contact-form-label">Desired Grade Level *</label>
          <select id="grade-level" name="grade-level" required>
            <option value="" disabled selected>Select a grade level</option>
            <option value="pre-k">Pr&eacute;-Escola (Ages 4-5)</option>
            <option value="k">Kindergarten (Ages 5-6)</option>
            <option value="1-2">Grades 1-2</option>
            <option value="3-5">Grades 3-5</option>
            <option value="6-8">Grades 6-8</option>
            <option value="9-12">Grades 9-12</option>
          </select>
        </div>
      </fieldset>

      <div class="contact-form-group">
        <label for="message" class="contact-form-label">Questions or Comments</label>
        <textarea id="message" name="message" rows="5" placeholder="Tell us about your child's Portuguese language experience, any questions you have, or special considerations..."></textarea>
      </div>

      <div class="contact-form-actions">
        <button type="submit" class="btn-primary">Submit Enrollment Inquiry</button>
        <p class="contact-form-note">* Required fields. We'll contact you within 2 business days.</p>
      </div>
    </form>
  </div>
</section>
