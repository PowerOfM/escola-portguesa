---
import site from '../data/site.json';
---

<footer>
  <div class="container">
    <div class="footer-main">
      <div class="footer-brand">
        <div class="footer-logo">
          <img src="/assets/images/logo-footer.png" alt="Escola Portuguesa Logo" />
          <span>{site.name}</span>
        </div>
        <p>{site.tagline}</p>
      </div>

      <div class="footer-links">
        <div class="footer-links-column">
          <h3>Quick Links</h3>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/about#our-teachers">Teachers</a></li>
            <li><a href="/children">Children's Classes</a></li>
            <li><a href="/adults">Adults Classes</a></li>
            <li><a href="/calendar">Important Dates</a></li>
          </ul>
        </div>

        <div class="footer-links-column">
          <h3>Contact Us</h3>
          <div class="footer-contact">
            <div class="footer-contact-item">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.67"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
              <span>
                {site.address.name}<br />
                {site.address.street}<br />
                {site.address.city}, {site.address.province} {site.address.postal}
              </span>
            </div>
            <div class="footer-contact-item">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.67"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect width="20" height="16" x="2" y="4" rx="2" />
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
              <span>{site.email.general}</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; 2026 {site.shortName}. All rights reserved.</p>
    </div>
  </div>
</footer>
